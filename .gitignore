```
# Kotlin/Android build artifacts
*.class
*.dex
*.jar
*.aar
*.so
*.dylib
*.dll

# Gradle
.gradle/
build/
app/build/

# Local configuration file (sdk path, etc)
local.properties

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio profiler trace files
*.trace

# Code coverage
coverage/
*.ec
*.lcov

# Proguard folder generated by Eclipse
proguard/

# Compiled JNI libraries
lib/

# IDE
.idea/
*.iml
*.ipr
*.iws

# Temporary files
*.tmp
*.temp
*.bak

# Environment variables
.env
.env.local
*.env.*

# Python cache (if present in Android project)
__pycache__/
*.pyc
*.pyo
.Python

# Node modules (if present in Android project)
node_modules/

# OS generated files
.DS_Store
Thumbs.db
```