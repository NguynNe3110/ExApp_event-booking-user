<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.uzuu.customer.feature.middle.home.HomeFragment"
        android:label="Home">
        <argument
            android:name="usernameStr"
            app:argType="string"
            android:defaultValue=""/>
        <action
            android:id="@+id/action_homeFragment_to_eventDetail"
            app:destination="@id/eventDetailFragment" />
        <action
            android:id="@+id/action_homeFragment_to_categoryEventsFragment"
            app:destination="@id/categoryEventsFragment" />
    </fragment>

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.uzuu.customer.feature.middle.cart.CartFragment"
        android:label="Cart">
        <action
            android:id="@+id/action_cartFragment_to_checkoutFragment"
            app:destination="@id/checkoutFragment" />
    </fragment>

    <fragment
        android:id="@+id/checkoutFragment"
        android:name="com.uzuu.customer.feature.middle.checkout.CheckoutFragment"
        android:label="Xac nhan thanh toan">
        <argument
            android:name="itemIds"
            app:argType="long[]"
            app:nullable="false" />
        <action
            android:id="@+id/action_checkoutFragment_to_voucherListFragment"
            app:destination="@id/voucherListFragment" />
    </fragment>

    <fragment
        android:id="@+id/voucherListFragment"
        android:name="com.uzuu.customer.feature.middle.voucher.VoucherListFragment"
        android:label="Chon voucher" />

    <fragment
        android:id="@+id/blogFragment"
        android:name="com.uzuu.customer.feature.middle.blog.BlogFragment"
        android:label="Blog"/>

    <fragment
        android:id="@+id/blogDetailFragment"
        android:name="com.uzuu.customer.feature.middle.blog.BlogDetailFragment"
        android:label="Chi tiết bài viết">
        <argument android:name="blogId" app:argType="long" />
        <argument android:name="title" app:argType="string" android:defaultValue="" />
        <argument android:name="content" app:argType="string" android:defaultValue="" />
        <argument android:name="thumbnail" app:argType="string" android:defaultValue="" />
        <argument android:name="authorName" app:argType="string" android:defaultValue="" />
        <argument android:name="publishedAt" app:argType="string" android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/ticketFragment"
        android:name="com.uzuu.customer.feature.middle.ticket.TicketFragment"
        android:label="Ticket"/>

    <fragment
        android:id="@+id/personalFragment"
        android:name="com.uzuu.customer.feature.middle.personal.PersonalFragment"
        android:label="Personal">
        <action
            android:id="@+id/action_personal_to_editInfo"
            app:destination="@id/personalInfoFragment"/>
        <action
            android:id="@+id/action_personal_to_history"
            app:destination="@id/historyFragment"/>
        <action
            android:id="@+id/action_personal_to_changePassword"
            app:destination="@id/changePasswordFragment"/>
    </fragment>

    <fragment
        android:id="@+id/personalInfoFragment"
        android:name="com.uzuu.customer.feature.middle.personal.personalInfo.PersonalInfoFragment"
        android:label="Chỉnh sửa thông tin"/>

    <fragment
        android:id="@+id/changePasswordFragment"
        android:name="com.uzuu.customer.feature.middle.personal.changePassword.ChangePasswordFragment"
        android:label="Đổi mật khẩu" />

    <fragment
        android:id="@+id/eventDetailFragment"
        android:name="com.uzuu.customer.feature.middle.home.eventDetail.EventDetailFragment"
        android:label="Chi tiết sự kiện">
        <argument
            android:name="event"
            app:argType="com.uzuu.customer.domain.model.Event" />
    </fragment>

    <fragment
        android:id="@+id/categoryEventsFragment"
        android:name="com.uzuu.customer.feature.middle.home.eventExtra.CategoryEventsFragment"
        android:label="Sự kiện theo danh mục">
        <argument
            android:name="categoryId"
            app:argType="long" />
        <argument
            android:name="categoryName"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.uzuu.customer.feature.middle.personal.history.HistoryFragment"
        android:label="Lịch sử đơn hàng"/>

</navigation>
