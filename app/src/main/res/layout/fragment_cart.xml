<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/blue_bg_1">

    <!-- Header -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:shapeAppearanceOverlay="@style/CardRoundedTop"
        app:contentPadding="14dp"
        android:backgroundTint="@color/blue_surface_9"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="🛒  Giỏ hàng"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/blue_text_dark"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear_cart"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Xóa tất cả"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/blue_primary_550"
                app:strokeColor="@color/blue_primary_550"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Toolbar chọn tất cả + xóa đã chọn (chỉ hiện khi có item) -->
    <LinearLayout
        android:id="@+id/toolbar_selection"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:visibility="gone"
        android:background="@color/blue_bg_3">

        <CheckBox
            android:id="@+id/checkbox_select_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn tất cả"
            android:textSize="14sp"
            android:textColor="@color/blue_text_dark"/>

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete_selected"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Xóa đã chọn"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textColor="@color/event_ongoing"
            app:strokeColor="@color/event_ongoing"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp"/>
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:visibility="gone"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Giỏ hàng trống 🛒"
        android:textSize="18sp"
        android:textColor="@color/blue_text_secondary"
        android:visibility="gone"/>

    <!-- Danh sách -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_cart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:visibility="gone"
        tools:listitem="@layout/item_cart_item"
        tools:visibility="visible"/>

    <!-- Footer thanh toán -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_checkout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        android:backgroundTint="@color/white"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tổng tiền tất cả / đã chọn -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tv_total_label"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Tổng cộng:"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0đ"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#E53935"/>
            </LinearLayout>

            <!-- Phương thức thanh toán -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phương thức thanh toán"
                android:textSize="14sp"
                android:textColor="@color/blue_text_primary"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <AutoCompleteTextView
                    android:id="@+id/dropdown_payment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BANKING"
                    android:textSize="15sp"
                    android:focusable="false"
                    android:inputType="none"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Hai nút: Thanh toán đã chọn | Thanh toán tất cả -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_checkout_selected"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:text="Mục đã chọn"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textColor="@color/blue_primary_550"
                    app:strokeColor="@color/blue_primary_550"
                    app:cornerRadius="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_checkout"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:text="Tất cả"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    app:backgroundTint="@color/blue_primary_550"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>